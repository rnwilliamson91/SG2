; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TopDown Survival Shooter"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Events="*res://autoload/events.gd"
Run="*res://autoload/run.gd"
SpellCatalog="*res://autoload/spell_catalog.gd"
SpellIcons="*res://autoload/spell_icons.gd"
SpellProgress="*res://autoload/spell_progress.gd"
LevelUp="*res://autoload/level_up.gd"
InputDefaults="*res://autoload/input_defaults.gd"
SpriteFactory="*res://autoload/SpriteFactory.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[input]

ui_cancel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player_body"
2d_physics/layer_3="mob_body"
2d_physics/layer_4="player_hurtbox"
2d_physics/layer_5="mob_hurtbox"
2d_physics/layer_6="projectile_player"
2d_physics/layer_7="projectile_enemy"
2d_physics/layer_8="pickup"

[physics]

3d/physics_engine="Jolt Physics"
2d/default_gravity=0.0

[rendering]

rendering_device/driver.windows="d3d12"
